{
  "name": "restaurant-booking-system",
  "version": "0.1.0",
  "private": true,
  "description": "Mobile-first internal restaurant booking system",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "db:up": "docker compose up -d postgres",
    "compose:up": "docker compose up -d --build",
    "compose:logs": "docker compose logs -f app postgres",
    "db:down": "docker compose down",
    "db:logs": "docker compose logs -f postgres",
    "migrate": "node src/db/migrate.js",
    "seed": "node src/db/seed.js",
    "db:setup": "npm run migrate && npm run seed",
    "test": "node --test",
    "check": "node --check src/server.js && node --check public/dashboard.js && node --check public/theme.js && node --test"
  },
  "dependencies": {
    "bootstrap": "^5.3.3",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "hbs": "^4.2.0",
    "pg": "^8.13.1",
    "socket.io": "^4.8.1"
  },
  "devDependencies": {
    "nodemon": "^3.1.9"
  }
}
