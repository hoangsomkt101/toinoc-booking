<main class="container min-vh-100 d-flex align-items-center justify-content-center py-5">
  <section class="card error-card border-0 shadow-sm w-100">
    <div class="card-body p-4 p-sm-5">
      <img class="auth-logo mb-4" src="/logo.webp" alt="Restaurant Booking">
      <p class="eyebrow mb-1">{{statusCode}}</p>
      <h1 class="h2 fw-bold mb-3">{{message}}</h1>
      <p class="text-body-secondary mb-4">Hãy chạy migration và tạo dữ liệu mẫu trước khi mở trang tổng quan.</p>
      <a class="btn btn-warning fw-bold" href="/">Quay lại trang tổng quan</a>
    </div>
  </section>
</main>
