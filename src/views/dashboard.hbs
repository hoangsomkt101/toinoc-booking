{{#if isBookingsSection}}
  {{#if showOperationsSummary}}
    <section class="metric-grid mb-4" aria-label="Tình hình theo ngày được chọn">
      <article class="metric">
        <strong id="count-today">0</strong>
        <small>Đặt bàn</small>
      </article>
      <article class="metric green">
        <strong id="count-available-tables">0</strong>
        <small>Bàn trống</small>
      </article>
      <article class="metric">
        <strong id="count-occupied-tables">0</strong>
        <small>Đang ngồi</small>
      </article>
    </section>
  {{/if}}
{{/if}}

{{#if isBookingsSection}}
  {{#if canManageBookings}}
    <section class="booking-alert-grid mb-3" id="booking-alerts" aria-label="Thông báo đặt bàn" hidden></section>
    <div class="booking-board">
      <section class="booking-section">
        <div class="section-title">
          <span>Dòng thời gian đặt bàn</span>
          <span class="section-title-note">Lọc theo trạng thái</span>
        </div>
        <div class="booking-tabs" id="booking-tabs" aria-label="Lọc danh sách đặt bàn"></div>
        <div class="booking-card-list" id="open-booking-list"></div>
      </section>
    </div>
  {{/if}}
{{/if}}

{{#if isBranchesSection}}
  <section class="admin-panel">
    <div class="section-title mt-0">
      <span>Chi nhánh</span>
      <span class="section-title-note">Cấu hình</span>
    </div>
    <div>
      <p class="text-body-secondary small mb-3">Các địa điểm nhà hàng được sử dụng cho đặt bàn, bàn và tài khoản nhân viên.</p>
      {{#if canManageBranches}}
        <button class="btn btn-outline-secondary mb-3" type="button" data-open-management-popup="branch-create">Tạo chi nhánh</button>
        <p class="form-message small text-body-secondary mb-3" id="branch-form-message" role="status"></p>
      {{else}}
        <div class="alert alert-warning mb-3" role="note">Chỉ quản trị viên có thể tạo hoặc chỉnh sửa chi nhánh.</div>
      {{/if}}
      <div class="branch-card-grid" id="branch-list"></div>
    </div>
  </section>
{{/if}}

{{#if isCustomersSection}}
  <section class="admin-panel">
    <div class="section-title mt-0">
      <span>Khách hàng</span>
      <span class="section-title-note">Lịch sử đặt bàn</span>
    </div>
    <div>
      {{#if canViewCustomerPhones}}
        <p class="text-body-secondary small mb-3">Số điện thoại là khóa khách hàng. Khi tạo booking, nhập số đã từng đặt sẽ tự điền nhanh tên và hiển thị lịch sử gần nhất.</p>
      {{else}}
        <p class="text-body-secondary small mb-3">Danh sách khách hàng theo phạm vi chi nhánh. Số điện thoại chỉ hiển thị với quản trị viên.</p>
      {{/if}}
      <div class="customer-toolbar mb-3">
        <label class="visually-hidden" for="customer-search">Tìm khách hàng</label>
        <input class="form-control" id="customer-search" type="search" placeholder="{{#if canViewCustomerPhones}}Tìm theo tên hoặc số điện thoại{{else}}Tìm theo tên khách hàng{{/if}}" autocomplete="off" data-customer-search>
      </div>
      <p class="form-message small text-body-secondary mb-3" id="customer-form-message" role="status"></p>
      <div class="customer-card-grid" id="customer-list"></div>
    </div>
  </section>
{{/if}}

{{#if isUsersSection}}
  <section class="admin-panel">
    <div class="section-title mt-0">
      <span>Tài khoản người dùng</span>
      <span class="section-title-note">Quản trị</span>
    </div>
    <div>
      <p class="text-body-secondary small mb-3">Quản trị viên có thể tạo, cập nhật và vô hiệu hóa mọi vai trò người dùng.</p>
      <button class="btn btn-outline-secondary mb-3" type="button" data-open-management-popup="user-create">Tạo tài khoản</button>
      <p class="form-message small text-body-secondary mb-3" id="user-form-message" role="status"></p>
      <div id="user-list"></div>
    </div>
  </section>
{{/if}}

{{#if isSettingsSection}}
  {{#if canManageApiSettings}}
  <section class="admin-panel mb-4">
    <div class="section-title mt-0">
      <span>API Settings</span>
      <span class="section-title-note">Tích hợp</span>
    </div>
    <div>
      <p class="text-body-secondary small mb-3">Quản trị viên cho phép domain bên ngoài đọc danh sách chi nhánh public và tạo booking bằng API key, không dùng cookie đăng nhập nội bộ.</p>
      <button class="btn btn-outline-secondary mb-3" type="button" data-open-management-popup="api-client-create">Tạo API key</button>
      <p class="form-message small text-body-secondary mb-3" id="api-client-form-message" role="status"></p>
      <div class="alert alert-warning small" role="note">API key chỉ hiển thị một lần khi tạo hoặc xoay key. Hãy lưu trong WordPress server-side, không đưa vào HTML/JavaScript public.</div>
      <div id="api-client-list"></div>
    </div>
  </section>
  {{/if}}

  {{#if canManageSheetSettings}}
  <section class="admin-panel">
    <div class="section-title mt-0">
      <span>Sheet Settings</span>
      <span class="section-title-note">Đồng bộ đơn</span>
    </div>
    <div>
      <p class="text-body-secondary small mb-3">Cấu hình tối đa 2 link Google Apps Script: Sheet tổng và Sheet chia chi nhánh. Link chia chi nhánh tự chọn tab theo địa chỉ chi nhánh trong Apps Script.</p>
      <button class="btn btn-outline-secondary mb-3" type="button" data-open-management-popup="sheet-target-create">Tạo cấu hình Sheet</button>
      <p class="form-message small text-body-secondary mb-3" id="sheet-target-form-message" role="status"></p>
      <div class="alert alert-warning small" role="note">Payload gửi đi gồm: date, time, people, address, name, tel, note. Trường address dùng địa chỉ chi nhánh để Apps Script chia tab CN_Quan1, CN_BinhThanh, CN_Q10, CN_GV hoặc BookingData.</div>
      <div id="sheet-target-list"></div>
    </div>
  </section>
  {{/if}}
{{/if}}
