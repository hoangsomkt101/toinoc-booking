<div class="booking-popup management-popup overlay-shell" id="management-popup" data-management-popup hidden aria-hidden="true">
  <div class="booking-popup-backdrop" data-close-management-popup></div>
  <section class="booking-popup-panel management-popup-panel bottom-sheet" role="dialog" aria-modal="true" aria-labelledby="management-popup-title" tabindex="-1" data-management-popup-panel>
    <div class="sheet-handle" aria-hidden="true"></div>
    <div class="booking-popup-header management-popup-header">
      <div>
        <p class="eyebrow mb-1" data-management-popup-eyebrow>Quản trị</p>
        <h3 class="screen-title fs-2 mb-0" id="management-popup-title" data-management-popup-title>Thao tác</h3>
      </div>
      <button class="btn btn-soft rounded-circle booking-close-button" type="button" data-close-management-popup aria-label="Đóng popup">X</button>
    </div>
    <div class="booking-popup-body management-popup-body" data-management-popup-body></div>
  </section>
</div>
