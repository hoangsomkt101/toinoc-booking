<!doctype html>
<html lang="vi">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>{{title}}</title>
    <link rel="icon" type="image/webp" href="/fav.webp">
    <link rel="stylesheet" href="/vendor/bootstrap/css/bootstrap.min.css">
    <link rel="stylesheet" href="/styles.css">
  </head>
  <body>
    <main class="container min-vh-100 d-flex align-items-center justify-content-center py-5">
      <section class="card auth-card border-0 shadow-sm w-100">
        <div class="card-body p-4 p-sm-5">
          <img class="auth-logo mb-4" src="/logo.webp" alt="Restaurant Booking">
          <p class="eyebrow mb-1">Dành cho nhân viên</p>
          <h1 class="display-5 fw-bold mb-2">Đăng nhập</h1>
          <p class="text-body-secondary mb-4">Đăng nhập bằng tên đăng nhập và mật khẩu nhân viên.</p>

          {{#if error}}
            <div class="alert alert-danger" role="alert">{{error}}</div>
          {{/if}}

          <form class="d-grid gap-3" method="post" action="/login">
            <input type="hidden" name="next" value="{{next}}">
            <div>
              <label class="form-label fw-semibold">Tên đăng nhập</label>
              <input class="form-control form-control-lg" name="username" value="{{username}}" autocomplete="username" autocapitalize="none" required autofocus>
            </div>
            <div>
              <label class="form-label fw-semibold">Mật khẩu</label>
              <input class="form-control form-control-lg" name="password" type="password" autocomplete="current-password" required>
            </div>
            <button class="btn btn-warning btn-lg fw-bold mt-2" type="submit">Đăng nhập</button>
          </form>
        </div>
      </section>
    </main>
  </body>
</html>
